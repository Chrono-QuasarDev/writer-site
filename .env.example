# Copy this file to .env and fill in your values
# cp .env.example .env

# ------------------------------------------------------------
# Required
# ------------------------------------------------------------

# Password used to log in to the admin panel.
# Required in production (the server refuses to start without it).
ADMIN_PASSWORD=your-strong-password-here

# Random string used to sign session cookies.
# Required in production. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-random-session-secret-here

# ------------------------------------------------------------
# Optional
# ------------------------------------------------------------

# 'development' or 'production'. In production:
#  - secure cookies are enabled (requires HTTPS)
#  - trust proxy is set (req.ip honours X-Forwarded-For)
#  - required env vars above are enforced
NODE_ENV=development

# HTTP port (default 3000). Most hosts set this for you.
PORT=3000

# Where to keep database.db. Defaults to <project>/database.db
# in development. In production, point this at a persistent
# volume so deploys don't wipe your data:
#   DATABASE_PATH=/data/database.db
# DATABASE_PATH=

# Where to keep uploaded cover images. Defaults to
# <project>/public/uploads in development. In production:
#   UPLOADS_DIR=/data/uploads
# UPLOADS_DIR=
