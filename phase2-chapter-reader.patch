diff --git a/controllers/chapterController.js b/controllers/chapterController.js
index 7cb08f7..7b976ab 100644
--- a/controllers/chapterController.js
+++ b/controllers/chapterController.js
@@ -1,8 +1,85 @@
-// Placeholder — logic added when we build chapter features
+const db = require('../config/database');
+
 const chapterController = {
-  showChapter: (req, res) => {
-    res.send('chapterController.showChapter — not yet implemented');
+  /**
+   * GET /chapters/:id
+   * Render a single chapter, plus prev/next navigation within its book.
+   * A chapter is only visible when:
+   *   - is_published = 1
+   *   - publish_date IS NULL OR publish_date <= today
+   * Unpublished or future-scheduled chapters return 404 (not 403) so we
+   * don't leak the existence of draft content.
+   */
+  showChapter: async (req, res, next) => {
+    try {
+      const chapterId = Number.parseInt(req.params.id, 10);
+
+      if (!Number.isInteger(chapterId) || chapterId <= 0) {
+        return res.status(404).send('404 - Chapter not found');
+      }
+
+      const chapter = await db.getAsync(
+        `SELECT id, book_id, title, chapter_number, content, publish_date, is_published
+           FROM chapters
+          WHERE id = ?
+            AND is_published = 1
+            AND (publish_date IS NULL OR publish_date <= DATE('now'))`,
+        [chapterId]
+      );
+
+      if (!chapter) {
+        return res.status(404).send('404 - Chapter not found');
+      }
+
+      const book = await db.getAsync(
+        `SELECT id, title FROM books WHERE id = ?`,
+        [chapter.book_id]
+      );
+
+      // Defensive: if the parent book was deleted but the chapter row
+      // somehow remains (shouldn't happen with ON DELETE CASCADE, but...).
+      if (!book) {
+        return res.status(404).send('404 - Chapter not found');
+      }
+
+      // Find the previous and next *published* chapters within the same book,
+      // by chapter_number. Two small queries keep memory low even for long books.
+      const prevChapter = await db.getAsync(
+        `SELECT id, chapter_number, title
+           FROM chapters
+          WHERE book_id = ?
+            AND is_published = 1
+            AND (publish_date IS NULL OR publish_date <= DATE('now'))
+            AND chapter_number < ?
+          ORDER BY chapter_number DESC
+          LIMIT 1`,
+        [chapter.book_id, chapter.chapter_number]
+      );
+
+      const nextChapter = await db.getAsync(
+        `SELECT id, chapter_number, title
+           FROM chapters
+          WHERE book_id = ?
+            AND is_published = 1
+            AND (publish_date IS NULL OR publish_date <= DATE('now'))
+            AND chapter_number > ?
+          ORDER BY chapter_number ASC
+          LIMIT 1`,
+        [chapter.book_id, chapter.chapter_number]
+      );
+
+      res.render('chapter-read', {
+        title: `${book.title} — Chapter ${chapter.chapter_number}`,
+        extraCss: 'reader',
+        book,
+        chapter,
+        prevChapter,
+        nextChapter,
+      });
+    } catch (err) {
+      next(err);
+    }
   },
 };
 
-module.exports = chapterController;
\ No newline at end of file
+module.exports = chapterController;
diff --git a/public/css/reader.css b/public/css/reader.css
index 9a5e8ba..f348946 100644
--- a/public/css/reader.css
+++ b/public/css/reader.css
@@ -1,7 +1,188 @@
-/* Reading-specific styles — to be expanded */
+/* ============================================
+   Reader-specific styles
+   Loaded on the chapter reading page via extraCss.
+   Uses tokens defined in main.css (--color-*, --space-*, etc.)
+   ============================================ */
+
+/* --------------------------------------------
+   Breadcrumb back link (above the article)
+   -------------------------------------------- */
+.reader-crumb {
+  max-width: 680px;
+  margin: 0 auto var(--space-lg);
+}
+
+.reader-crumb__link {
+  font-family: var(--font-sans);
+  font-size: 0.9375rem;
+  color: var(--color-text-muted);
+}
+.reader-crumb__link:hover {
+  color: var(--color-accent);
+}
+
+/* --------------------------------------------
+   Reader article wrapper — narrow column for prose
+   -------------------------------------------- */
+.reader {
+  max-width: 680px;
+  margin: 0 auto;
+}
+
+/* --------------------------------------------
+   Header (book + chapter title)
+   -------------------------------------------- */
+.reader__header {
+  margin-bottom: var(--space-xl);
+  padding-bottom: var(--space-lg);
+  border-bottom: 1px solid var(--color-border);
+  text-align: center;
+}
+
+.reader__eyebrow {
+  font-family: var(--font-sans);
+  font-size: 0.8125rem;
+  text-transform: uppercase;
+  letter-spacing: 0.08em;
+  color: var(--color-text-muted);
+  margin-bottom: var(--space-sm);
+}
+
+.reader__book-link {
+  color: var(--color-text-muted);
+  text-decoration: none;
+  border-bottom: 1px dotted transparent;
+  transition: color var(--transition), border-color var(--transition);
+}
+.reader__book-link:hover {
+  color: var(--color-accent);
+  border-bottom-color: var(--color-accent);
+}
+
+.reader__sep {
+  margin: 0 var(--space-xs);
+  opacity: 0.5;
+}
+
+.reader__title {
+  font-family: var(--font-serif);
+  font-size: 2rem;
+  line-height: 1.2;
+  font-weight: 600;
+  color: var(--color-text);
+}
+
+/* --------------------------------------------
+   Chapter content — long-form prose
+   -------------------------------------------- */
+.reader__content {
+  font-family: var(--font-serif);
+  font-size: 1.125rem;
+  line-height: 1.8;
+  color: var(--color-text);
+  /* preserve paragraph breaks from plain-text content */
+  white-space: pre-wrap;
+  /* hyphenate gracefully on narrow screens */
+  hyphens: auto;
+  margin-bottom: var(--space-2xl);
+}
+
+.reader__empty {
+  font-style: italic;
+  color: var(--color-text-muted);
+  text-align: center;
+  padding: var(--space-xl) 0;
+}
+
+/* --------------------------------------------
+   Prev / Next navigation footer
+   -------------------------------------------- */
+.reader-nav {
+  display: grid;
+  grid-template-columns: 1fr 1fr;
+  gap: var(--space-md);
+  padding-top: var(--space-lg);
+  border-top: 1px solid var(--color-border);
+}
+
+.reader-nav__slot {
+  /* Empty slot still takes its column so Next stays right-aligned
+     even when Previous is absent (and vice versa). */
+  min-height: 1px;
+}
+
+.reader-nav__slot--next {
+  text-align: right;
+}
+
+.reader-nav__link {
+  display: inline-flex;
+  flex-direction: column;
+  gap: var(--space-xs);
+  padding: var(--space-md);
+  border: 1px solid var(--color-border);
+  border-radius: var(--radius-md);
+  background: var(--color-surface);
+  color: var(--color-text);
+  font-family: var(--font-sans);
+  text-align: left;
+  width: 100%;
+  transition: border-color var(--transition),
+              box-shadow var(--transition),
+              transform var(--transition);
+}
+
+.reader-nav__link--next {
+  text-align: right;
+}
+
+.reader-nav__link:hover {
+  border-color: var(--color-accent);
+  box-shadow: var(--shadow-card-hover);
+  color: var(--color-text);
+  transform: translateY(-2px);
+}
+
+.reader-nav__link:focus-visible {
+  outline: 2px solid var(--color-accent);
+  outline-offset: 2px;
+}
+
+.reader-nav__direction {
+  font-size: 0.75rem;
+  text-transform: uppercase;
+  letter-spacing: 0.08em;
+  color: var(--color-accent);
+  font-weight: 600;
+}
+
+.reader-nav__chapter-title {
+  font-size: 0.9375rem;
+  line-height: 1.4;
+  color: var(--color-text);
+}
+
+/* --------------------------------------------
+   Responsive: stack nav on narrow screens
+   -------------------------------------------- */
+@media (max-width: 540px) {
+  .reader-nav {
+    grid-template-columns: 1fr;
+  }
+  .reader-nav__slot--next,
+  .reader-nav__link--next {
+    text-align: left;
+  }
+}
+
+/* --------------------------------------------
+   Legacy class kept for backward-compat — used
+   by anything that targeted `.chapter-content`
+   before the reader layout existed.
+   -------------------------------------------- */
 .chapter-content {
   max-width: 680px;
   margin: 0 auto;
   font-size: 1.1rem;
   line-height: 1.8;
-}
\ No newline at end of file
+}
diff --git a/views/chapter-read.ejs b/views/chapter-read.ejs
new file mode 100644
index 0000000..44b3aea
--- /dev/null
+++ b/views/chapter-read.ejs
@@ -0,0 +1,54 @@
+<%- include('partials/header') %>
+
+<nav class="reader-crumb">
+  <a href="/books/<%= book.id %>" class="reader-crumb__link">
+    ← Back to <%= book.title %>
+  </a>
+</nav>
+
+<article class="reader">
+  <header class="reader__header">
+    <p class="reader__eyebrow">
+      <a href="/books/<%= book.id %>" class="reader__book-link">
+        <%= book.title %>
+      </a>
+      <span class="reader__sep">·</span>
+      Chapter <%= chapter.chapter_number %>
+    </p>
+    <h1 class="reader__title"><%= chapter.title %></h1>
+  </header>
+
+  <div class="reader__content">
+    <% if (chapter.content && chapter.content.trim().length > 0) { %>
+      <%= chapter.content %>
+    <% } else { %>
+      <p class="reader__empty">This chapter has no content yet.</p>
+    <% } %>
+  </div>
+
+  <nav class="reader-nav" aria-label="Chapter navigation">
+    <div class="reader-nav__slot reader-nav__slot--prev">
+      <% if (prevChapter) { %>
+        <a href="/chapters/<%= prevChapter.id %>" class="reader-nav__link">
+          <span class="reader-nav__direction">← Previous</span>
+          <span class="reader-nav__chapter-title">
+            Chapter <%= prevChapter.chapter_number %>: <%= prevChapter.title %>
+          </span>
+        </a>
+      <% } %>
+    </div>
+
+    <div class="reader-nav__slot reader-nav__slot--next">
+      <% if (nextChapter) { %>
+        <a href="/chapters/<%= nextChapter.id %>" class="reader-nav__link reader-nav__link--next">
+          <span class="reader-nav__direction">Next →</span>
+          <span class="reader-nav__chapter-title">
+            Chapter <%= nextChapter.chapter_number %>: <%= nextChapter.title %>
+          </span>
+        </a>
+      <% } %>
+    </div>
+  </nav>
+</article>
+
+<%- include('partials/footer') %>
-- 
