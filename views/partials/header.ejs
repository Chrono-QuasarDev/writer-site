<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' — Writer Site' : 'Writer Site' %></title>
  <link rel="stylesheet" href="/css/main.css" />
  <% if (typeof extraCss !== 'undefined') { %>
    <link rel="stylesheet" href="/css/<%= extraCss %>.css" />
  <% } %>
</head>
<body>
  <header class="site-header">
    <div class="container site-header__inner">
      <a href="/" class="site-header__brand">Writer Site</a>
      <nav class="site-header__nav">
        <a href="/">Library</a>
        <% if (isAdmin) { %>
          <a href="/admin/dashboard">Dashboard</a>
          <form class="site-header__logout" method="POST" action="/admin/logout">
            <button type="submit" class="site-header__logout-btn">Log out</button>
          </form>
        <% } %>
      </nav>
    </div>
  </header>
  <main class="container site-main">