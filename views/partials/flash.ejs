<% if (typeof flash !== 'undefined' && (flash.success || flash.error)) { %>
  <div class="flash-stack" role="status" aria-live="polite">
    <% if (flash.success) { %>
      <div class="flash flash--success"><%= flash.success %></div>
    <% } %>
    <% if (flash.error) { %>
      <div class="flash flash--error"><%= flash.error %></div>
    <% } %>
  </div>
<% } %>
